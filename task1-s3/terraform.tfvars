
# Deploy all gallery resources in Frankfurt (eu-central-1).
aws_region = "eu-central-1"

# Prefix for the gallery bucket and CloudFront resources.
project_name = "s3-task-images"

# Folder inside task1-s3/ that holds the 5–10 .jpg gallery images.
images_dir = "images"

# Owner tag value applied to every AWS resource.
owner = "mukesh"
